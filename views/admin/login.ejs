<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - CERDAS BERKARAKTER CMS</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --purple-900: #2D1B4E;
            --purple-700: #4A2D7A;
            --purple-600: #5B2D8E;
            --pink-600: #D63384;
            --pink-500: #E91E8C;
            --gray-50: #F9FAFB;
            --gray-100: #F3F4F6;
            --gray-200: #E5E7EB;
            --gray-300: #D1D5DB;
            --gray-400: #9CA3AF;
            --gray-600: #4B5563;
            --gray-800: #1F2937;
            --white: #FFFFFF;
            --success: #10B981;
            --error: #EF4444;
        }
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, var(--purple-900) 0%, #1a0f2e 100%);
            padding: 20px;
        }
        .login-container { width: 100%; max-width: 420px; }
        .login-card {
            background: var(--white);
            border-radius: 24px;
            padding: 48px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        }
        .login-header { text-align: center; margin-bottom: 32px; }
        .login-logo {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            margin-bottom: 16px;
        }
        .login-logo img { height: 48px; }
        .login-logo-text {
            font-size: 1.25rem;
            font-weight: 800;
            color: var(--purple-900);
        }
        .login-logo-text span { color: var(--pink-500); }
        .login-header h1 {
            font-size: 1.5rem;
            color: var(--gray-800);
            margin-bottom: 8px;
        }
        .login-header p { color: var(--gray-600); font-size: 0.9375rem; }
        .form-group { margin-bottom: 20px; }
        .form-label {
            display: block;
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--gray-800);
            margin-bottom: 8px;
        }
        .form-input {
            width: 100%;
            padding: 14px 16px;
            font-size: 1rem;
            border: 2px solid var(--gray-200);
            border-radius: 12px;
            transition: all 0.3s ease;
            font-family: inherit;
        }
        .form-input:focus {
            outline: none;
            border-color: var(--purple-700);
            box-shadow: 0 0 0 4px rgba(74, 45, 122, 0.1);
        }
        .btn {
            width: 100%;
            padding: 16px;
            font-size: 1rem;
            font-weight: 600;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-family: inherit;
        }
        .btn-primary {
            background: linear-gradient(135deg, var(--purple-700) 0%, var(--pink-600) 100%);
            color: var(--white);
            box-shadow: 0 4px 14px rgba(214, 51, 132, 0.4);
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(214, 51, 132, 0.5);
        }
        .error-message {
            background: #FEE2E2;
            color: var(--error);
            padding: 12px 16px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-size: 0.875rem;
        }
        .back-link {
            display: block;
            text-align: center;
            margin-top: 24px;
            color: var(--gray-600);
            text-decoration: none;
            font-size: 0.875rem;
            transition: color 0.3s ease;
        }
        .back-link:hover { color: var(--purple-700); }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-card">
            <div class="login-header">
                <div class="login-logo">
                    <img src="/assets/images/logo.png" alt="Logo" onerror="this.style.display='none'">
                    <span class="login-logo-text">CERDAS<span>BERKARAKTER</span></span>
                </div>
                <h1>Welcome Back</h1>
                <p>Login ke Admin Dashboard</p>
            </div>
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="error-message"><%= error %></div>
            <% } %>
            <form action="/auth/login" method="POST">
                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input type="email" name="email" class="form-input" placeholder="admin@cerdasberkarakter.id" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Password</label>
                    <input type="password" name="password" class="form-input" placeholder="Masukkan password" required>
                </div>
                <button type="submit" class="btn btn-primary">Login</button>
            </form>
            <a href="/" class="back-link">← Kembali ke Landing Page</a>
        </div>
    </div>
</body>
</html>
